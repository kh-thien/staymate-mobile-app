# === Flutter Ignore Rules ===

# 🔒 Bảo mật
.env
.env.*
*.pem
*.key
*.p12
*.crt
# google-services.json
# GoogleService-Info.plist
secrets.json
credentials.json

# ⚙️ Build & Generated
build/
.ios/
.android/
web/
linux/
windows/
macos/
coverage/
.flutter-plugins
.flutter-plugins-dependencies
.packages
pubspec.lock
.dart_tool/

# 🧹 IDE, Cache
.idea/
.vscode/
.DS_Store

# 🧪 Test artifacts, logs
*.log
test_output/
*.tmp

# 📦 Node (nếu có web integration)
node_modules/

# 🚫 Không để AI đọc file ảnh hay media lớn
assets/images/
assets/videos/
assets/audio/

# ✅ Nhưng cho phép file config chính
!lib/
!pubspec.yaml
!analysis_options.yaml
!README.md
